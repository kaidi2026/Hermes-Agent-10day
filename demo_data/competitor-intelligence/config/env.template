# Hermes Agent 竞品情报监控 环境变量配置
# 文件位置：~/.hermes/profiles/competitor-intelligence/.env
# 使用前请将 YOUR_xxx 替换为真实值

# ============================================
# LLM API Key（必填，至少配一个）
# ============================================
# 阿里云百炼 Token Plan
OPENAI_API_KEY=YOUR_API_KEY_HERE

# ============================================
# 飞书 Webhook（推荐，即时告警用）
# ============================================
# 获取方式：飞书群 → 设置 → 群机器人 → 自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_ID

# ============================================
# 个人微信推送（可选，二选一）
# ============================================
# 方案一：Server酱（推荐，免费）
# 获取方式：https://sct.ftqq.com 微信扫码登录 → 获取 SendKey
SERVERJIAN_SENDKEY=YOUR_SENDKEY_HERE

# 方案二：PushPlus
# 获取方式：https://www.pushplus.plus 微信扫码登录 → 获取 Token
# PUSHPLUS_TOKEN=YOUR_TOKEN_HERE